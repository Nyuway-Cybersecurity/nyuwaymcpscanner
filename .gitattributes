# Normalize line endings to LF in the repo, checkout as-is on all platforms
* text=auto eol=lf

# Force LF for files that must not have CRLF
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yar text eol=lf
*.json text eol=lf

# Binary files - no line ending conversion
*.png binary
*.jpg binary
*.whl binary
*.tar.gz binary
